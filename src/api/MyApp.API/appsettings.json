{
  "DatabaseProvider": "SqlServer",
  "ConnectionStrings": {
    "DefaultConnection": "Server=db,1433;Database=MyAppDb;User Id=sa;Password=${DB_PASSWORD};TrustServerCertificate=True;",
    "Redis": "redis:6379",
    "RabbitMQ": "amqp://rabbitmq:rabbitmq@rabbitmq:5672/"
  },
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "MyApp",
    "Audience": "MyApp",
    "ExpiryMinutes": 60
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "rabbitmq",
    "Password": "${RABBITMQ_PASSWORD}",
    "VirtualHost": "/"
  },
  "OpenTelemetry": {
    "ServiceName": "MyApp.API",
    "OtlpEndpoint": "http://otel-collector:4317"
  },
  "Serilog": {
    "SeqUrl": "http://seq:5341"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://your-dashboard-domain.com"
  ],
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
