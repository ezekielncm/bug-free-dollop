# Database
DB_PROVIDER=SqlServer
DB_PASSWORD=YourStrong@Passw0rd
DB_CONNECTION_STRING=Server=db,1433;Database=MyAppDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;

# PostgreSQL (when using DB_PROVIDER=PostgreSQL)
POSTGRES_PASSWORD=myapp_password

# JWT
JWT_SECRET_KEY=super-secret-key-change-in-production-min-32-chars!

# Redis (leave empty for no password)
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_PASSWORD=rabbitmq

# Grafana
GRAFANA_PASSWORD=admin

# Docker registry (for CD)
DOCKER_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

# API URL for dashboard (production)
API_URL=https://api.yourdomain.com
